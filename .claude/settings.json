{
  "description": "permission + config, committed",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo tree:*)",
      "Bash(diesel migration:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\"file_path\"\\s*:\\s*\"[^\"]*\\.env\"'; then echo 'BLOCKED: Reading .env files is not allowed — contains secrets'; exit 2; fi",
            "description": "Block reading .env files to protect secrets"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\"file_path\"\\s*:\\s*\"[^\"]*\\.env\"'; then echo 'BLOCKED: Writing .env files is not allowed — contains secrets'; exit 2; fi",
            "description": "Block writing/editing .env files to protect secrets"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt -- --quiet",
            "filePattern": "**/*.rs",
            "description": "Auto-format Rust files after edit"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo clippy --quiet -- -D warnings 2>&1 | head -30",
            "filePattern": "**/*.rs",
            "description": "Run clippy lint after editing Rust files"
          }
        ]
      }
    ]
  }
}
