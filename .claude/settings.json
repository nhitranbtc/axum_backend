{
  "description": "permission + config, committed",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo audit:*)",
      "Bash(cargo deny:*)",
      "Bash(cargo tree:*)",
      "Bash(diesel migration:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "filePattern": "**/*.rs",
        "command": "cargo fmt -- --quiet",
        "description": "Auto-format Rust files after edit"
      },
      {
        "matcher": "Edit|Write",
        "filePattern": "**/*.rs",
        "command": "cargo clippy --quiet -- -D warnings 2>&1 | head -30",
        "description": "Run clippy lint after editing Rust files"
      }
    ]
  }
}
