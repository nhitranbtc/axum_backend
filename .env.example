# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
RUST_LOG=info,axum_backend=debug

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=900        # 15 minutes in seconds
JWT_REFRESH_EXPIRY=604800    # 7 days in seconds

# ── ScyllaDB ──────────────────────────────────────────────────────────────────
SCYLLA_NODES=localhost:9042
SCYLLA_KEYSPACE=axum_backend
SCYLLA_USERNAME=
SCYLLA_PASSWORD=
SCYLLA_REPLICATION_FACTOR=1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# ── NATS ──────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_USER=myuser
NATS_PASSWORD=mypass
NATS_TOKEN=

# ── SMTP (Email) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=no-reply@example.com
CONFIRMATION_CODE_EXPIRY=60   # Seconds until confirmation code expires

# ── gRPC (optional) ──────────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_REFLECTION_ENABLED=true
GRPC_WEB_ENABLED=true
GRPC_MAX_CONNECTIONS=100
GRPC_ACTOR_POOL_SIZE=20
GRPC_CORS_ORIGINS=*
